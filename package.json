{
  "name": "narsil",
  "version": "2.0.0",
  "private": true,
  "description": "The fastest backend for Next.js applications",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf packages/*/dist",
    "typecheck": "tsc --build --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "drizzle-orm": "^0.45.2",
    "react": "^19.2.4",
    "typescript": "^5.9.3",
    "vitest": "^3.1.1"
  }
}
